APP_NAME=SOCLY
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

# Czech Locale
APP_LOCALE=cs
APP_FALLBACK_LOCALE=cs
APP_FAKER_LOCALE=cs_CZ
APP_TIMEZONE=Europe/Prague

# Database
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=socly
DB_USERNAME=postgres
DB_PASSWORD=

# Storage (use 'public' for local dev, 's3' for production with R2)
FILESYSTEM_DISK=public
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=auto
AWS_BUCKET=socly-media
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=true

# Mail (Resend)
MAIL_MAILER=resend
MAIL_FROM_ADDRESS=noreply@socly.eu
MAIL_FROM_NAME="${APP_NAME}"
RESEND_KEY=

# Laravel Reverb (WebSockets)
BROADCAST_DRIVER=reverb
REVERB_APP_ID=123456
REVERB_APP_KEY=localkey
REVERB_APP_SECRET=localsecret
REVERB_HOST=localhost
REVERB_PORT=8080
REVERB_SCHEME=http

# Queue & Cache
QUEUE_CONNECTION=database
CACHE_STORE=file
SESSION_DRIVER=database
SESSION_LIFETIME=120

# Redis (F6.1 — set on VPS after: apt install redis-server)
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# For production, switch to:
# CACHE_STORE=redis
# SESSION_DRIVER=redis
# QUEUE_CONNECTION=redis

# NOWPayments (F2.3)
NOWPAYMENTS_API_KEY=
NOWPAYMENTS_IPN_SECRET=

# Sentry (error tracking — https://sentry.io)
SENTRY_LARAVEL_DSN=
VITE_SENTRY_DSN=

# LiveKit (live streaming — https://cloud.livekit.io)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=

# OpenAI (AI moderace — moderation endpoint je ZDARMA)
OPENAI_API_KEY=

# Session Security (set these in production)
SESSION_ENCRYPT=true
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=strict
SESSION_HTTP_ONLY=true

# Logging
LOG_CHANNEL=stack
LOG_LEVEL=debug

# ═══════════════════════════════════════════
# PRODUCTION CHECKLIST — change these values:
# ═══════════════════════════════════════════
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://socly.app
# SESSION_DRIVER=database
# SESSION_SECURE_COOKIE=true
# SESSION_SAME_SITE=strict
# CACHE_STORE=redis (if available)
# LOG_LEVEL=warning
# MAIL_MAILER=smtp
